{
    "compilerOptions": {
        "target": "es2016",
        "module": "commonjs",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "noImplicitAny": false // TODO: remove once ts migration is complete
    },
    "$schema": "https://www.schemastore.org/tsconfig"
}
